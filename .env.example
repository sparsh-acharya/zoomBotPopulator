# Zoom Marketplace General App credentials.
# In a Zoom "General App", the same Client ID/Secret are used BOTH as the
# Meeting SDK key/secret (for signatures) AND as the OAuth client credentials.
ZOOM_SDK_KEY=your_client_id
ZOOM_SDK_SECRET=your_client_secret

# OAuth redirect — must EXACTLY match the redirect URL configured on the Zoom app.
# For local dev behind a tunnel, use the HTTPS tunnel URL + /oauth/callback.
ZOOM_OAUTH_REDIRECT_URI=https://your-tunnel.example.dev/oauth/callback

# ── Built-in ngrok tunnel (optional) ──────────────────────────────────────────
# If NGROK_DOMAIN is set, `npm start` opens the tunnel automatically — no need to
# run `ngrok http ...` separately. Leave blank to manage your own tunnel.
# Use the reserved domain WITHOUT https:// (e.g. my-app.ngrok-free.dev).
NGROK_DOMAIN=your-tunnel.example.dev
# Your ngrok authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken

# Optional: only set these if your OAuth app credentials differ from the
# Meeting SDK key/secret above (separate apps instead of one General App).
# ZOOM_OAUTH_CLIENT_ID=
# ZOOM_OAUTH_CLIENT_SECRET=

# Presenter (screen-share) bots must render to a display to capture pixels.
# Leave false to run them headed (wrap the server in `xvfb-run` on Linux).
# Set true ONLY if your Chromium build supports headless getDisplayMedia.
HOST_BOT_HEADLESS=false

# HTTP port for the dashboard + bot pages (optional, default 3000)
PORT=3000

# Required Zoom OAuth scopes for the General App (granular scope names):
#   meeting:write:meeting   (create the scheduled meeting)
#   user:read:user          (read profile — "connected as ...")
#   user:read:zak           (ZAK token — lets the bot START the meeting)
# After adding/changing scopes you MUST reconnect (re-authorize) so a new token
# is issued — existing tokens keep their old scopes.
